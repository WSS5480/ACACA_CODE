<% content_for :email_title do %>
  Tu número de cliente
<% end %>

<p style="margin-bottom: 20px;">
  ¡Hola <%= @user&.name || '' %>!
</p>

<p style="margin-bottom: 20px;">
  Hemos recibido tu solicitud para recuperar tu número de cliente.
  Aquí está tu información:
</p>

<table cellpadding="0" cellspacing="0" border="0" style="margin: 30px 0; width: 100%;">
  <tr>
    <td style="background-color: #f5f5f5; padding: 20px; border-radius: 8px; text-align: center;">
      <p style="margin: 0 0 8px 0; font-size: 14px; color: #666;">
        Tu número de cliente es:
      </p>
      <p style="margin: 0; font-size: 32px; font-weight: bold; color: #333; letter-spacing: 2px;">
        <%= @user.number %>
      </p>
    </td>
  </tr>
</table>

<p style="margin-bottom: 20px;">
  Guarda este número en un lugar seguro. Lo necesitarás para acceder a tu cuenta.
</p>

<p style="margin-bottom: 20px;">
  Si no solicitaste esta información, puedes ignorar este correo de forma segura.
</p>

