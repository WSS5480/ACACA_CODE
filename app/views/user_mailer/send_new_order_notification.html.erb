<% content_for :email_title do %>
  Nueva orden #<%= @order.id %>
<% end %>

<p style="margin-bottom: 20px;">
  Se ha registrado una nueva orden en acasa.
</p>

<table cellpadding="0" cellspacing="0" border="0" style="margin: 30px 0; width: 100%; border-collapse: collapse;">
  <tr>
    <td style="background-color: #f5f5f5; padding: 16px; border: 1px solid #eee;">
      <strong>ID orden</strong>
    </td>
    <td style="padding: 16px; border: 1px solid #eee;">
      #<%= @order.id %>
    </td>
  </tr>
  <tr>
    <td style="background-color: #f5f5f5; padding: 16px; border: 1px solid #eee;">
      <strong>Cliente</strong>
    </td>
    <td style="padding: 16px; border: 1px solid #eee;">
      <%= @order.user_name %> <%= @order.user_last_name %> (<%= @order.user_email %>)
    </td>
  </tr>
  <tr>
    <td style="background-color: #f5f5f5; padding: 16px; border: 1px solid #eee;">
      <strong>Producto</strong>
    </td>
    <td style="padding: 16px; border: 1px solid #eee;">
      <%= @order.product_title %> (ASIN: <%= @order.product_asin %>)
    </td>
  </tr>
  <tr>
    <td style="background-color: #f5f5f5; padding: 16px; border: 1px solid #eee;">
      <strong>Enganche</strong>
    </td>
    <td style="padding: 16px; border: 1px solid #eee;">
      <%= number_to_currency(@order.downpayment) %>
    </td>
  </tr>
  <tr>
    <td style="background-color: #f5f5f5; padding: 16px; border: 1px solid #eee;">
      <strong>Crédito usado</strong>
    </td>
    <td style="padding: 16px; border: 1px solid #eee;">
      <%= number_to_currency(@order.used_credit) %>
    </td>
  </tr>
  <tr>
    <td style="background-color: #f5f5f5; padding: 16px; border: 1px solid #eee;">
      <strong>Pago semanal</strong>
    </td>
    <td style="padding: 16px; border: 1px solid #eee;">
      <%= number_to_currency(@order.weekly_payment) %>
    </td>
  </tr>
  <tr>
    <td style="background-color: #f5f5f5; padding: 16px; border: 1px solid #eee;">
      <strong>Fecha</strong>
    </td>
    <td style="padding: 16px; border: 1px solid #eee;">
      <%= l(@order.created_at, format: :long) %>
    </td>
  </tr>
</table>

